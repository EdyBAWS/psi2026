generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusGeneral {
  Activ
  Inactiv
}

enum StatusReparatie {
  IN_ASTEPTARE_DIAGNOZA
  ASTEAPTA_APROBARE_CLIENT
  IN_ASTEPTARE_PIESE
  IN_LUCRU
  FINALIZAT
  FACTURAT
  ANULAT
}

enum TipClient {
  PF
  PJ
}

enum TipAngajat {
  Manager
  Mecanic
  Receptioner
  Inspector
}

enum TipPiesa {
  NOUA
  SH
}

enum StatusFactura {
  Emisa
  Platita
  Anulata
}

enum ModalitateIncasare {
  TransferBancar
  POS
  Cash
}

enum TipNotificare {
  Info
  Avertizare
  Succes
}

model Client {
  idClient    Int           @id @default(autoincrement())
  tipClient   TipClient
  status      StatusGeneral @default(Activ)
  nume        String
  prenume     String?
  telefon     String
  email       String?
  adresa      String
  soldDebitor Float         @default(0)
  CNP         String?       @unique
  serieCI     String?
  CUI         String?       @unique
  IBAN        String?
  nrRegCom    String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  facturas    Factura[]
  incasari    Incasare[]
  vehicule    Vehicul[]
  dosareDauna DosarDauna[]
  comenzi     Comanda[]     // Legatura adaugata pentru comenzile directe
}

model Angajat {
  idAngajat     Int           @id @default(autoincrement())
  status        StatusGeneral @default(Activ)
  nume          String
  prenume       String
  CNP           String        @unique
  telefon       String
  email         String?
  tipAngajat    TipAngajat
  specializare  String?
  costOrar      Float?
  departament   String?
  sporConducere Float?
  nrBirou       String?
  tura          String?
  
  createdAt     DateTime      @default(now())
  comenziCreate   Comanda[]     @relation("ComandaCreator")
  comenziLucrate  Comanda[]     @relation("ComandaMecanic")
  dosareInspectate DosarDauna[] @relation("InspectorDosare")
}

model Asigurator {
  idAsigurator    Int           @id @default(autoincrement())
  status          StatusGeneral @default(Activ)
  denumire        String
  CUI             String        @unique
  nrRegCom        String?
  adresa          String?
  telefon         String
  emailDaune      String?
  IBAN            String?
  termenPlataZile Int           @default(30)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  dosareDauna DosarDauna[]
  facturi     Factura[]    // Facturi emise pe asigurator (varianta A - plata directa)
  incasari    Incasare[]   // Incasari de la asigurator
}

model Vehicul {
  idVehicul          Int           @id @default(autoincrement())
  numarInmatriculare String        @unique
  marca              String
  model              String
  vin                String?       @unique
  status             StatusGeneral @default(Activ)
  
  idClient           Int
  client             Client        @relation(fields: [idClient], references: [idClient])
  
  dosareDauna        DosarDauna[]
  comenzi            Comanda[]     // Legatura adaugata pentru comenzile directe
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Piesa {
  idPiesa      Int      @id @default(autoincrement())
  codPiesa     String   @unique
  denumire     String
  producator   String
  categorie    String
  pretBaza     Float
  stoc         Int      @default(0)
  tip          TipPiesa
  luniGarantie Int?
  gradUzura    String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  kituriIteme  KitPiesaItem[]
}

model KitPiese {
  idKit      Int            @id @default(autoincrement())
  codKit     String         @unique
  denumire   String
  reducere   Float?         @default(0) // Procent reducere

  piese      KitPiesaItem[]
  
  comandaPozitii ComandaPozitie[]
  facturaIteme   FacturaItem[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model KitPiesaItem {
  idItem    Int      @id @default(autoincrement())
  
  idKit     Int
  kit       KitPiese @relation(fields: [idKit], references: [idKit], onDelete: Cascade)
  
  idPiesa   Int
  piesa     Piesa    @relation(fields: [idPiesa], references: [idPiesa])
  
  cantitate Int      @default(1)
  
  createdAt DateTime @default(now())
}

model Manopera {
  idManopera  Int      @id @default(autoincrement())
  codManopera String   @unique
  denumire    String
  categorie   String
  durataStd   Float
  pretOra     Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DosarDauna {
  idDosar        Int           @id @default(autoincrement())
  numarDosar     String        @unique
  dataDeschidere DateTime      @default(now())
  status         StatusGeneral @default(Activ)
  
  idClient       Int
  client         Client        @relation(fields: [idClient], references: [idClient])
  
  idVehicul      Int
  vehicul        Vehicul       @relation(fields: [idVehicul], references: [idVehicul])
  
  idAsigurator   Int?
  asigurator     Asigurator?   @relation(fields: [idAsigurator], references: [idAsigurator])
  
  idInspector    Int?
  inspector      Angajat?      @relation("InspectorDosare", fields: [idInspector], references: [idAngajat])
  
  comenzi        Comanda[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Comanda {
  idComanda       Int           @id @default(autoincrement())
  numarComanda    String        @unique
  dataPreconizata DateTime?

  status          StatusReparatie @default(IN_ASTEPTARE_DIAGNOZA)
  
  idDosar         Int?
  dosar           DosarDauna?   @relation(fields: [idDosar], references: [idDosar])
  
  idAngajat       Int?
  creator         Angajat?      @relation("ComandaCreator", fields: [idAngajat], references: [idAngajat])
  
  mecanici        Angajat[]     @relation("ComandaMecanic")

  // --- CÂMPURI NOI PENTRU COMENZI FĂRĂ DOSAR ---
  idClient        Int?
  client          Client?       @relation(fields: [idClient], references: [idClient])
  
  idVehicul       Int?
  vehicul         Vehicul?      @relation(fields: [idVehicul], references: [idVehicul])

  pozitii         ComandaPozitie[] // Relația către piesele/manopera din deviz
  facturi         Factura[]
  notificari      Notificare[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// --- TABEL NOU PENTRU DEVIZ ---
model ComandaPozitie {
  idPozitie   Int      @id @default(autoincrement())
  
  idComanda   Int
  comanda     Comanda  @relation(fields: [idComanda], references: [idComanda], onDelete: Cascade)
  
  tipArticol  String   // "PIESA", "MANOPERA", "KIT"
  idArticol   Int?     // idPiesa sau idManopera
  idKit       Int?     // idKit separat daca e cazul
  kit         KitPiese? @relation(fields: [idKit], references: [idKit], onDelete: SetNull)

  codArticol  String?
  descriere   String
  unitateMasura String?
  cantitate   Float
  pretUnitar  Float
  discount    Float    @default(0)
  cotaTva     Float    @default(19)
  observatii  String?
  
  createdAt   DateTime @default(now())
}

model Factura {
  idFactura    Int               @id @default(autoincrement())
  serie        String            @default("SN")
  numar        Int               @unique
  dataEmiterii DateTime          @default(now())
  scadenta     DateTime
  status       StatusFactura     @default(Emisa)
  
  idClient     Int
  client       Client            @relation(fields: [idClient], references: [idClient])
  
  // Asiguratorul care plateste (Varianta A - factura pe asigurator)
  // Cand este setat, idClient = beneficiar (proprietarul masinii), idAsigurator = platitor
  idAsigurator Int?
  asigurator   Asigurator?       @relation(fields: [idAsigurator], references: [idAsigurator])
  
  idComanda    Int?
  comanda      Comanda?          @relation(fields: [idComanda], references: [idComanda])
  
  iteme        FacturaItem[]
  incasari     IncasareAlocare[]
  notificari   Notificare[]
  
  totalFaraTVA   Float             @default(0)
  discountProcent Float             @default(0)
  tva            Float             @default(0)
  totalGeneral   Float             @default(0)
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model FacturaItem {
  idItem     Int      @id @default(autoincrement())
  
  idFactura  Int
  factura    Factura  @relation(fields: [idFactura], references: [idFactura])
  
  descriere  String
  cantitate  Float
  pretUnitar Float
  cotaTva    Float    @default(19)
  idPiesa    Int?
  idManopera Int?
  idKit      Int?
  kit        KitPiese? @relation(fields: [idKit], references: [idKit], onDelete: SetNull)
  
  createdAt  DateTime @default(now())
}

model Incasare {
  idIncasare Int                @id @default(autoincrement())
  
  // Clientul beneficiar (proprietarul masinii) - optional pentru incasari de la asigurator
  idClient   Int?
  client     Client?            @relation(fields: [idClient], references: [idClient])
  
  // Asiguratorul platitor (Varianta A - plata directa de la asigurator)
  idAsigurator Int?
  asigurator   Asigurator?      @relation(fields: [idAsigurator], references: [idAsigurator])
  
  data       DateTime           @default(now())
  suma       Float
  modalitate ModalitateIncasare
  referinta  String?
  
  alocari    IncasareAlocare[]
  
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model IncasareAlocare {
  idAlocare   Int      @id @default(autoincrement())
  
  idIncasare  Int
  incasare    Incasare @relation(fields: [idIncasare], references: [idIncasare], onDelete: Cascade)
  
  idFactura   Int
  factura     Factura  @relation(fields: [idFactura], references: [idFactura])
  
  sumaAlocata Float
  createdAt   DateTime @default(now())
}

model Notificare {
  idNotificare     Int           @id @default(autoincrement())
  tip              TipNotificare @default(Info)
  mesaj            String
  data             DateTime      @default(now())
  paginaDestinatie String?
  sursaModul       String?
  textActiune      String?
  citit            Boolean       @default(false)
  arhivata         Boolean       @default(false)
  stearsa          Boolean       @default(false)
  
  idFactura        Int?
  factura          Factura?      @relation(fields: [idFactura], references: [idFactura])
  
  idComanda        Int?
  comanda          Comanda?      @relation(fields: [idComanda], references: [idComanda])
  
  metadata         Json?
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}